# LLM_PROFILE selecciona el backend activo por defecto (env-based)
# Valores: local | openai | anthropic
# Si el cliente envía llm_config en el body, ese config tiene prioridad sobre LLM_PROFILE.
LLM_PROFILE=local

# --- Backend local (Ollama) ---
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL_FAST=qwen3:8b
OLLAMA_MODEL_CAPABLE=qwen3:8b

# --- Backend producción (OpenAI) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_CAPABLE=gpt-4o

# --- Backend producción (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_CAPABLE=claude-sonnet-4-6

# --- Backend producción (Google Gemini) ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_CAPABLE=gemini-2.5-pro

# --- Proxy navegador (transport=browser en llm_config) ---
# URL interna del gateway Node.js (nunca expuesta al exterior)
GATEWAY_INTERNAL_URL=http://localhost:3001
# Token secreto compartido entre agente y gateway para el endpoint /internal/llm
INTERNAL_PROXY_SECRET=cambia-esto-en-produccion

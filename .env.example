# Variables para docker-compose. Copia a `.env` y rellena.
# Recuerda además rellenar agent/.env (perfil + credenciales del LLM).

# --- Supabase cloud (compartido backend + frontend) ---
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Frontend (build-time; se hornean en el bundle) ---
# Apuntan al backend tal y como lo ve el NAVEGADOR, no la red interna de compose.
# Para despliegue local con los puertos publicados:
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# --- Secreto compartido backend <-> agent (proxy LLM interno) ---
INTERNAL_PROXY_SECRET=<cadena-aleatoria-larga>

# --- Opcionales del backend (tienen defaults) ---
RATE_LIMIT=5
RATE_LIMIT_WINDOW_SECONDS=60
CACHE_TTL_DAYS=30
